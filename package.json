{
  "name": "@mrkaran/hodor",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.6.0-rc.9",
  "description": "AI-powered code review agent that finds bugs, security issues, and logic errors in pull requests",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hodor": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist",
    "templates"
  ],
  "keywords": [
    "ai",
    "code-review",
    "github",
    "gitlab",
    "pr",
    "automation",
    "agent",
    "hodor"
  ],
  "author": "Karan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mr-karan/hodor"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "@anthropic-ai/sdk": "^0.95.2",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
